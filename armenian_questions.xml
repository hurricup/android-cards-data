    <questions>
        <question>
            <text>ով</text>
            <answer>кто (читается օվ, исключение)</answer>
        </question>
        <question>
            <text>ովքեր</text>
            <answer>кты (мн. число кто, читается օվքեր, исключение)</answer>
        </question>
        <question>
            <text>ինչ</text>
            <answer>что (какой в общих вопросах)</answer>
        </question>
        <question>
            <text>երբ</text>
            <answer>когда</answer>
        </question>
        <question>
            <text>ոնց</text>
            <answer>как</answer>
        </question>
        <question>
            <text>ինչպես</text>
            <answer>как</answer>
        </question>
        <question>
            <text>ինչու</text>
            <answer>почему</answer>
        </question>
        <question>
            <text>խի</text>
            <answer>почему</answer>
        </question>
        <question>
